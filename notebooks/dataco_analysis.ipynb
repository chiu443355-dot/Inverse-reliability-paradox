import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("../datasets/dataco.csv")

late_rates = df.groupby("Shipping Mode")["Late_delivery_risk"].mean()

print(late_rates)

late_rates.plot(kind="bar")
plt.title("Late Delivery Risk by Shipping Mode")
plt.ylabel("Late Delivery Rate")
plt.show()
