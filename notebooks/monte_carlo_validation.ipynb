import numpy as np
import matplotlib.pyplot as plt

runs = 10000

premium_failure = []
standard_failure = []

for _ in range(runs):
    congestion = np.random.uniform(0.6, 1.0)

    premium = congestion**2 + np.random.normal(0, 0.05)
    standard = congestion * 0.8 + np.random.normal(0, 0.05)

    premium_failure.append(premium)
    standard_failure.append(standard)

plt.hist(premium_failure, alpha=0.6, label="Premium")
plt.hist(standard_failure, alpha=0.6, label="Standard")
plt.legend()
plt.title("Monte Carlo Reliability Divergence")
plt.show()
